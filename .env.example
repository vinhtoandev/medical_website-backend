# Environment Configuration Template
# Copy this file to .env and fill in the actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=derma_insight
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Spring Datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/derma_insight
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-characters-required

# AWS S3 Configuration
AWS_S3_BUCKET=derma-insight-prod
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key

# Spring Profile (dev, prod)
SPRING_PROFILES_ACTIVE=dev
